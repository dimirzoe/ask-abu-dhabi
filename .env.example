# =============================================================================
# Ask Abu Dhabi — environment configuration
# Copy this file to `.env` and fill in the values. Never commit `.env`.
# All settings are read by core.config.Settings (pydantic-settings).
# =============================================================================

# --- LLM provider selection -------------------------------------------------
# Which provider the orchestrator uses. One of: openrouter | gemini
LLM_PROVIDER=openrouter

# --- OpenRouter -------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-your-key-here
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Google Gemini ----------------------------------------------------------
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# --- Generation parameters --------------------------------------------------
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT_SECONDS=30
# Retries on transient errors (429/500/503) with exponential backoff.
LLM_MAX_RETRIES=3
# KB-first + AI fallback: true = let the model fill gaps from general knowledge
# (with a verify-on-official-site note); false = strictly knowledge-base only.
LLM_ALLOW_GENERAL_KNOWLEDGE=true

# --- Knowledge base ---------------------------------------------------------
# Active KB written by the ETL pipeline. Falls back to the baseline if missing.
KB_PATH=data/knowledge_base.json
KB_BASELINE_PATH=data/baseline_knowledge_base.json
# A FRESH KB older than this many hours is downgraded to STALE.
KB_STALE_AFTER_HOURS=168

# --- Analytics --------------------------------------------------------------
ANALYTICS_DB_PATH=data/analytics.db

# --- ETL / Firecrawl --------------------------------------------------------
FIRECRAWL_API_KEY=fc-your-key-here
FIRECRAWL_BASE_URL=https://api.firecrawl.dev/v1
FIRECRAWL_TIMEOUT_SECONDS=120
# Minimum number of sources (out of 12) that must validate for an ETL run to
# atomically replace the existing knowledge base.
ETL_MIN_VALID_SOURCES=8

# --- App metadata -----------------------------------------------------------
APP_NAME=Ask Abu Dhabi
LOG_LEVEL=INFO
