# =============================================================================
# Streamlit Community Cloud secrets — TEMPLATE
# =============================================================================
# On Streamlit Cloud: app → Settings → Secrets → paste the lines below (with
# your real values). Do NOT commit a real secrets.toml — it is gitignored.
# These keys mirror the env vars in .env.example; app.py bridges them into the
# environment so core.config.Settings picks them up.

LLM_PROVIDER = "gemini"

# --- Gemini (active provider) ---
GEMINI_API_KEY = "AIza...your-NEW-rotated-key..."
GEMINI_MODEL = "gemini-2.5-flash"

# --- OpenRouter (optional fallback) ---
OPENROUTER_API_KEY = "sk-or-..."
OPENROUTER_MODEL = "anthropic/claude-sonnet-4.6"

# --- Behaviour ---
LLM_ALLOW_GENERAL_KNOWLEDGE = "true"
LLM_MAX_TOKENS = "2048"
LLM_MAX_RETRIES = "3"
